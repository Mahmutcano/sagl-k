# ── Backend (Go API) — ayrı deploy ─────────────────────────────────────────
# Bu dosyayı backend servisinin yanına kopyalayın: cp ../.env.example .env
# Tam anahtar listesi: repo kökü .env.example

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/medical_consultation?sslmode=require
JWT_SECRET=change-me-in-production-min-32-chars!!
API_PORT=8080

PORTAL_URL=https://app.ornek.edu.tr
DOCTOR_URL=https://app.ornek.edu.tr
ADMIN_URL=https://app.ornek.edu.tr

UPLOAD_DIR=/data/uploads

SMS_PROVIDER=mock
OTP_TTL=10m
EMAIL_PROVIDER=mock

PAYTR_MODE=mock
PAYTR_CALLBACK_URL=https://api.ornek.edu.tr/api/v1/payments/paytr/callback
PARASUT_MODE=mock

PAYMENT_AMOUNT=1500
DEFAULT_PAYMENT_PROVIDER=paytr
ERCIYES_MODE=mock
