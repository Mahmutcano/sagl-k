# ── Backend (Go API) — ayrı deploy ─────────────────────────────────────────
# Bu dosyayı backend servisinin yanına kopyalayın: cp .env.example .env

# Zorunlu
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/medical_consultation?sslmode=require
JWT_SECRET=change-me-in-production-min-32-chars!!

# Dinleme portu (Railway/Render PORT otomatik; yoksa API_PORT)
API_PORT=8080

# Frontend kök URL — CORS için (tek Next.js uygulaması; hepsi aynı domain olabilir)
PORTAL_URL=https://app.ornek.edu.tr
DOCTOR_URL=https://app.ornek.edu.tr
ADMIN_URL=https://app.ornek.edu.tr
# Ek origin (virgülle): önizleme domain, www vb.
# CORS_ALLOWED_ORIGINS=https://www.ornek.edu.tr,https://staging.ornek.edu.tr

# Yüklenen dosyalar (kalıcı disk / volume bağlayın)
UPLOAD_DIR=/data/uploads

# SMS / E-posta / Ödeme / Erciyes — kök .env.example ile aynı anahtarlar
SMS_PROVIDER=mock
# SMS doğrulama kodu geçerlilik süresi (ör. 10m, 5m)
OTP_TTL=10m
EMAIL_PROVIDER=mock
PARAM_MODE=test
BIZIMHESAP_MODE=test
ERCIYES_MODE=mock
PAYMENT_AMOUNT=1500
