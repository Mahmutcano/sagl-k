# ── Frontend (Next.js) — ayrı deploy ─────────────────────────────────────────
# Build ve runtime için platformda tanımlayın (Vercel/Railway/Docker build-arg)

# Canlı API adresi (sonunda / olmadan)
# Örnek: https://api.ornek.edu.tr
NEXT_PUBLIC_API_URL=https://api.ornek.edu.tr

# ── Sadece yerel geliştirme (NEXT_PUBLIC_API_URL boş bırakılırsa) ─────────────
# API_PROXY_TARGET=http://localhost:8080
