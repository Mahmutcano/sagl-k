# PostgreSQL — Railway veya yerel
# Railway örnek: postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require

# API
API_PORT=8080
JWT_SECRET=change-me-in-production-min-32-chars!!
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

# SMS (Netgsm / mevcut provider)
SMS_PROVIDER=mock
SMS_USERNAME=
SMS_PASSWORD=
SMS_HEADER=

# Email (SMTP / mevcut provider)
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Param ödeme
PARAM_CLIENT_CODE=
PARAM_CLIENT_USERNAME=
PARAM_CLIENT_PASSWORD=
PARAM_GUID=
PARAM_MODE=test
PARAM_API_URL=https://posws.param.com.tr/turkpos.ws/service_turkpos_prod.asmx

# Bizim Hesap
BIZIMHESAP_API_KEY=
BIZIMHESAP_FIRM_ID=
BIZIMHESAP_MODE=test
BIZIMHESAP_API_URL=https://api.bizimhesap.com

# Ödeme tutarı (TRY) ve varsayılan sağlayıcı (param | bizimhesap)
PAYMENT_AMOUNT=1500
DEFAULT_PAYMENT_PROVIDER=param

# Erciyes HIS web servisi (yatan hasta + hasta sorgu)
# mock: yerel simülasyon (TC son hanesi 0 = yatan hasta)
# live: ERCIYES_BASE_URL üzerinden gerçek servis
ERCIYES_MODE=mock
ERCIYES_BASE_URL=
ERCIYES_USERNAME=
ERCIYES_PASSWORD=
ERCIYES_API_KEY=
ERCIYES_PROTOCOL=json
ERCIYES_INPATIENT_PATH=/api/hasta/yatis-durumu
ERCIYES_PATIENT_PATH=/api/hasta/sorgula
ERCIYES_SOAP_ACTION=
ERCIYES_SOAP_NAMESPACE=http://erciyes.edu.tr/his
ERCIYES_TIMEOUT=10s
ERCIYES_TARGET_INSTITUTION=1
ERCIYES_BLOCK_ON_UNAVAILABLE=true

# PACS görüntüleyici
PACS_BASE_URL=https://pacs.example.com

# Frontend URL (CORS) — tek Next.js uygulaması
PORTAL_URL=http://localhost:3000
DOCTOR_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000

# Başvuru ek dosyaları (PDF, JPEG, PNG)
UPLOAD_DIR=./uploads
