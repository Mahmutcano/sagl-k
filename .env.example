# PostgreSQL — Railway veya yerel
# Railway örnek: postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require

# API
API_PORT=8080
JWT_SECRET=change-me-in-production-min-32-chars!!
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h
OTP_TTL=10m

# SMS — Verimor (mock | verimor). Legacy: netgsm
SMS_PROVIDER=mock
VERIMOR_USERNAME=
VERIMOR_PASSWORD=
VERIMOR_SOURCE_ADDR=
VERIMOR_API_URL=https://sms.verimor.com.tr/v2/send.json
# Legacy NetGSM (SMS_PROVIDER=netgsm)
# SMS_USERNAME=
# SMS_PASSWORD=
# SMS_HEADER=

# E-posta — MailerSend (mock | mailersend). Legacy: smtp
EMAIL_PROVIDER=mock
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=noreply@example.com
MAILERSEND_FROM_NAME=Erciyes Tibbi Danismanlik
CONTACT_INBOX_EMAIL=
# Legacy SMTP (EMAIL_PROVIDER=smtp)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# PAYTR — ödeme (mock | test | live)
# mock: iframe yok, frontend "Test ödemesini tamamla" ile simüle eder
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_MODE=mock
PAYTR_API_URL=https://www.paytr.com/odeme/api/get-token
# Public HTTPS callback (Railway API URL)
PAYTR_CALLBACK_URL=https://apiv1.example.com/api/v1/payments/paytr/callback
# Opsiyonel; {id} başvuru UUID ile değiştirilir
# PAYTR_OK_URL=https://app.example.com/patient/applications/{id}?payment=success
# PAYTR_FAIL_URL=https://app.example.com/patient/applications/{id}?payment=failed

# Paraşüt e-Fatura (mock | test | live)
PARASUT_CLIENT_ID=
PARASUT_CLIENT_SECRET=
PARASUT_COMPANY_ID=
PARASUT_USERNAME=
PARASUT_PASSWORD=
PARASUT_MODE=mock
PARASUT_API_URL=https://api.parasut.com

# Ödeme tutarı (TRY) — doktor ücreti yoksa fallback
PAYMENT_AMOUNT=1500
DEFAULT_PAYMENT_PROVIDER=paytr

# Erciyes HIS / PACS entegrasyonu
ERCIYES_MODE=mock
ERCIYES_BASE_URL=
ERCIYES_USERNAME=
ERCIYES_PASSWORD=
ERCIYES_API_KEY=
ERCIYES_PROTOCOL=json
ERCIYES_PATIENT_PATH=/api/hasta/sorgula
ERCIYES_SOAP_ACTION=
ERCIYES_SOAP_NAMESPACE=http://erciyes.edu.tr/his
ERCIYES_TIMEOUT=10s
ERCIYES_TARGET_INSTITUTION=1

PACS_BASE_URL=https://pacs.example.com

# Frontend URL (CORS)
PORTAL_URL=http://localhost:3000
DOCTOR_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
# CORS_ALLOWED_ORIGINS=https://www.example.com

# Frontend (ayrı deploy)
# NEXT_PUBLIC_API_URL=https://api.example.com

UPLOAD_DIR=./uploads
